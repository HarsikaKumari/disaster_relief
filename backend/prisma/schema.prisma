// ============================================
// DATABASE & GENERATOR
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  CITIZEN
  VOLUNTEER
  NGO
  ADMIN
}

enum Availability {
  AVAILABLE
  BUSY
  OFF_DUTY
  UNREACHABLE
}

enum EmergencyType {
  FLOOD
  EARTHQUAKE
  FIRE
  CYCLONE
  LANDSLIDE
  PANDEMIC
  ACCIDENT
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EmergencyStatus {
  PENDING
  VERIFIED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum ResourceType {
  FOOD
  WATER
  MEDICAL
  SHELTER
  TRANSPORT
  RESCUE_TEAM
  COMMUNICATION
  SANITATION
  CLOTHING
  ELECTRICITY
  OTHER
}

enum ResourceStatus {
  AVAILABLE
  IN_TRANSIT
  DEPLOYED
  DEPLETED
  RESERVED
}

enum NotificationType {
  EMERGENCY_ALERT
  RESOURCE_UPDATE
  VOLUNTEER_ASSIGNMENT
  STATUS_UPDATE
  MESSAGE
  SYSTEM
}

enum ChatMessageType {
  TEXT
  IMAGE
  LOCATION
  SYSTEM
  FILE
}

// ============================================
// USER MODEL
// ============================================

model User {
  id           String  @id @default(cuid())
  name         String
  email        String  @unique
  password     String
  phone        String  @unique
  role         Role    @default(CITIZEN)
  isVerified   Boolean @default(false)
  isActive     Boolean @default(true)
  profileImage String?

  // Location - Fixed: Decimal type
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)

  // Profile
  bio          String?
  skills       String[]
  availability Availability? @default(AVAILABLE)

  // Volunteer Stats
  verifiedVolunteer     Boolean   @default(false)
  verificationDate      DateTime?
  totalHoursVolunteered Int       @default(0)
  rating                Float?
  completedMissions     Int       @default(0)

  // Emergency Contact
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  // OTP Fields
  otp           String?
  otpExpiresAt  DateTime?
  otpAttempts   Int       @default(0)
  lastOtpSentAt DateTime?

  // Password Reset
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // Relations
  emergencies         Emergency[] @relation("ReportedEmergencies")
  assignedEmergencies Emergency[] @relation("AssignedEmergencies")

  notifications Notification[]

  chatMessages ChatMessage[]

  requestedResources ResourceRequest[] @relation("RequestedResources")
  approvedResources  ResourceRequest[] @relation("ApprovedResources")

  emergencyUpdates   EmergencyUpdate[]
  emergencyTimelines EmergencyTimeline[]

  sessions          Session[]
  auditLogs         AuditLog[]
  locationHistories LocationHistory[]

  rescueTeams RescueTeam[]
  resources   Resource[]

  chatMemberships ChatMember[]

  createdChatRooms ChatRoom[] @relation("CreatedChatRooms")

  generatedReports Report[]

  updatedConfigs SystemConfig[]
   messageReactions MessageReaction[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, phone])
  @@index([role])
  @@map("users")
}

// ============================================
// EMERGENCY MODEL
// ============================================

model Emergency {
  id          String          @id @default(cuid())
  title       String
  type        EmergencyType
  severity    Severity
  status      EmergencyStatus @default(PENDING)
  description String
  location    String
  latitude    Decimal         @db.Decimal(10, 8)
  longitude   Decimal         @db.Decimal(11, 8)

  // Priority & Response
  priority              Int     @default(0)
  autoAssigned          Boolean @default(false)
  estimatedResponseTime Int?
  actualResponseTime    Int?

  // Victim details
  reportedById String
  reportedBy   User    @relation("ReportedEmergencies", fields: [reportedById], references: [id])
  victimName   String?
  victimPhone  String?
  victimCount  Int     @default(1)

  // Images
  images String[]

  // Assignment
  assignedToId String?
  assignedTo   User?     @relation("AssignedEmergencies", fields: [assignedToId], references: [id])
  assignedAt   DateTime?

  // Resolution
  resolvedAt      DateTime?
  resolutionNotes String?

  // Metadata
  isPublic  Boolean @default(true)
  viewCount Int     @default(0)

  // Relations
  resourceRequests ResourceRequest[]
  updates          EmergencyUpdate[]
  timeline         EmergencyTimeline[]
  chatRooms        ChatRoom[]
  rescueTeams      RescueTeam[]
  deployments      ResourceDeployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, severity, createdAt])
  @@index([latitude, longitude])
  @@index([reportedById])
  @@index([assignedToId])
  @@map("emergencies")
}

// ============================================
// EMERGENCY UPDATE MODEL
// ============================================

model EmergencyUpdate {
  id          String          @id @default(cuid())
  emergencyId String
  emergency   Emergency       @relation(fields: [emergencyId], references: [id])
  status      EmergencyStatus
  message     String
  location    String?

  updatedById   String
  updatedBy     User?    @relation(fields: [updatedById], references: [id])
  updatedByName String
  images        String[]

  createdAt DateTime @default(now())

  @@index([emergencyId])
  @@index([createdAt])
  @@map("emergency_updates")
}

// ============================================
// EMERGENCY TIMELINE MODEL
// ============================================

model EmergencyTimeline {
  id            String    @id @default(cuid())
  emergencyId   String
  emergency     Emergency @relation(fields: [emergencyId], references: [id])
  action        String
  description   String
  performedById String
  performedBy   User      @relation(fields: [performedById], references: [id])
  metadata      Json?

  createdAt DateTime @default(now())

  @@index([emergencyId])
  @@index([createdAt])
  @@map("emergency_timeline")
}

// ============================================
// RESOURCE MODEL
// ============================================

model Resource {
  id           String       @id @default(cuid())
  name         String
  type         ResourceType
  description  String?
  quantity     Int          @default(1)
  availableQty Int          @default(1)
  unit         String       @default("units")

  // Location
  latitude  Decimal @db.Decimal(10, 8)
  longitude Decimal @db.Decimal(11, 8)
  location  String

  // Provider
  providerId   String
  provider     User   @relation(fields: [providerId], references: [id])
  providerName String

  // Status
  status     ResourceStatus @default(AVAILABLE)
  expiryDate DateTime?
  isActive   Boolean        @default(true)

  // Relations
  requests    ResourceRequest[]
  deployments ResourceDeployment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status, availableQty])
  @@index([latitude, longitude])
  @@index([providerId])
  @@map("resources")
}

// ============================================
// RESOURCE REQUEST MODEL - FIXED Ambiguous Relation
// ============================================

model ResourceRequest {
  id          String    @id @default(cuid())
  emergencyId String
  emergency   Emergency @relation(fields: [emergencyId], references: [id])
  resourceId  String
  resource    Resource  @relation(fields: [resourceId], references: [id])

  requestedQty Int
  approvedQty  Int?
  status       String @default("PENDING")

  requestedById String
  requestedBy   User    @relation("RequestedResources", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?   @relation("ApprovedResources", fields: [approvedById], references: [id])

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emergencyId, resourceId])
  @@index([status])
  @@map("resource_requests")
}

// ============================================
// RESOURCE DEPLOYMENT MODEL
// ============================================

model ResourceDeployment {
  id          String    @id @default(cuid())
  resourceId  String
  resource    Resource  @relation(fields: [resourceId], references: [id])
  emergencyId String
  emergency   Emergency @relation(fields: [emergencyId], references: [id])

  quantity    Int
  deployedAt  DateTime  @default(now())
  deliveredAt DateTime?
  status      String    @default("IN_TRANSIT")
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resourceId, emergencyId])
  @@index([status])
  @@map("resource_deployments")
}

// ============================================
// NOTIFICATION MODEL
// ============================================

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  type        NotificationType
  title       String
  message     String
  link        String?
  emergencyId String?
  resourceId  String?
  isRead      Boolean          @default(false)
  priority    Int              @default(0)
  readAt      DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([type])
  @@map("notifications")
}

// ============================================
// CHAT SYSTEM MODELS
// ============================================

model ChatRoom {
  id          String     @id @default(cuid())
  name        String?
  isGroup     Boolean    @default(false)
  emergencyId String?
  emergency   Emergency? @relation(fields: [emergencyId], references: [id])

  members       ChatMember[]
  messages      ChatMessage[]
  lastMessage   String?
  lastMessageAt DateTime?

  createdById String
  createdBy   User   @relation("CreatedChatRooms", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emergencyId])
  @@index([createdAt])
  @@map("chat_rooms")
}

model ChatMember {
  id     String   @id @default(cuid())
  roomId String
  room   ChatRoom @relation(fields: [roomId], references: [id])
  userId String
  user   User     @relation(fields: [userId], references: [id])

  joinedAt   DateTime @default(now())
  lastReadAt DateTime @default(now())
  isActive   Boolean  @default(true)

  @@unique([roomId, userId])
  @@map("chat_members")
}

model ChatMessage {
  id       String   @id @default(cuid())
  roomId   String
  room     ChatRoom @relation(fields: [roomId], references: [id])
  senderId String
  sender   User     @relation(fields: [senderId], references: [id])

  type     ChatMessageType @default(TEXT)
  content  String
  mediaUrl String?

  isRead Boolean   @default(false)
  readAt DateTime?
  reactions MessageReaction[]
  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
  @@map("chat_messages")
}

// ============================================
// LOCATION HISTORY MODEL
// ============================================

model LocationHistory {
  id         String  @id @default(cuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  latitude   Decimal @db.Decimal(10, 8)
  longitude  Decimal @db.Decimal(11, 8)
  entityType String
  entityId   String
  location   String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("location_histories")
}

// ============================================
// RESCUE TEAM MODEL
// ============================================

model RescueTeam {
  id       String   @id @default(cuid())
  name     String
  leaderId String
  leader   User     @relation(fields: [leaderId], references: [id])
  members  String[] // Array of User IDs

  emergencyId String?
  emergency   Emergency? @relation(fields: [emergencyId], references: [id])

  status String @default("STANDBY") // STANDBY, DEPLOYED, RETURNED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leaderId])
  @@index([emergencyId])
  @@map("rescue_teams")
}

// ============================================
// REPORT MODEL
// ============================================

model Report {
  id            String   @id @default(cuid())
  title         String
  description   String?
  type          String
  startDate     DateTime
  endDate       DateTime
  data          Json
  generatedById String
  generatedBy   User     @relation(fields: [generatedById], references: [id])
  fileUrl       String?

  createdAt DateTime @default(now())

  @@index([generatedById])
  @@index([createdAt])
  @@map("reports")
}

// ============================================
// SYSTEM CONFIG MODEL
// ============================================

model SystemConfig {
  id          String  @id @default(cuid())
  key         String  @unique
  value       Json
  description String?
  updatedById String?
  updatedBy   User?   @relation(fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ============================================
// SESSION MODEL
// ============================================

model Session {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  isActive   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

// ============================================
// AUDIT LOG MODEL
// ============================================

model AuditLog {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String
  details   Json
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  emoji     String   
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@map("message_reactions")
}